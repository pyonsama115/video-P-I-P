{
  "manifest_version": 3,
  "name": "Video PiP Topmost",
  "version": "0.3.4",
  "description": "YouTube と Netflix の動画を Windows / macOS の最前面に残る Picture-in-Picture で表示します。",
  "minimum_chrome_version": "111",
  "action": {
    "default_title": "動画を Picture-in-Picture で表示",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://youtu.be/*",
        "https://www.netflix.com/*",
        "https://netflix.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
